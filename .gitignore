@"
# Backend
backend/.env
backend/database.db
backend/database_backup.db
backend/uploads/*
!backend/uploads/.gitkeep
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.log

# Frontend
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/dist/
frontend/build/

# IDEs y Editores
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Otros
.git/
*.bak
*.tmp
"@ | Out-File -FilePath .gitignore -Encoding utf8